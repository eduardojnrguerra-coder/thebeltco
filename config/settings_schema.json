  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Font Settings"
      },
      {
        "type": "select",
        "id": "heading_font",
        "label": "Heading Font",
        "options": [
          { "value": "georgia", "label": "Georgia (Serif)" },
          { "value": "times", "label": "Times New Roman (Serif)" },
          { "value": "playfair", "label": "Playfair Display (Serif)" },
          { "value": "lora", "label": "Lora (Serif)" }
        ],
        "default": "georgia"
      },
      {
        "type": "select",
        "id": "body_font",
        "label": "Body Font",
        "options": [
          { "value": "system", "label": "System Font Stack" },
          { "value": "inter", "label": "Inter (Sans-Serif)" },
          { "value": "roboto", "label": "Roboto (Sans-Serif)" },
          { "value": "lato", "label": "Lato (Sans-Serif)" }
        ],
        "default": "system"
      },
      {
        "type": "range",
        "id": "base_font_size",
        "label": "Base Font Size",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading Scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "default": 125,
        "unit": "%"
      }
    ]
  },
