<section class="best-sellers">
  <div class="page-width">
    <div class="section-header">
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- assign collection = collections[section.settings.collection] -%}

    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="product-grid product-grid--{{ section.settings.grid }} columns-{{ section.settings.grid }}">
        {%- for product in collection.products limit: section.settings.product_limit -%}
          <div class="product-grid__item">
            {% render 'card-product', product: product, show_quick_add: section.settings.show_quick_add %}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="placeholder-section">
        <p>{{ 'collections.general.no_products' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best sellers",
  "tag": "section",
  "class": "section section--best-sellers",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select a collection of best-selling products"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "grid",
      "label": "Products per row (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Best sellers"
    }
  ]
}
{% endschema %}
