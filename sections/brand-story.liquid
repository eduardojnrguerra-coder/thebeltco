<section class="brand-story">
  <div class="page-width">
    <div class="brand-story__grid">
      <div class="brand-story__media">
        {%- if section.settings.image != blank -%}
          {%- assign brand_alt = section.settings.heading | escape -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: class: 'brand-story__image', widths: '400,600,800', sizes: '(max-width: 767px) 100vw, 50vw', alt: brand_alt, loading: 'lazy' }}
        {%- else -%}
          <div class="brand-story__image brand-story__image--placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
      <div class="brand-story__content">
        <h2 class="brand-story__heading">{{ section.settings.heading }}</h2>
        <div class="brand-story__text">{{ section.settings.text }}</div>
        {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
          <a href="{{ section.settings.btn_link }}" class="btn btn--outline brand-story__btn">
            {{ section.settings.btn_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "tag": "section",
  "class": "section section--brand-story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended: 800x800px, lifestyle or process photo"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handcrafted in South Africa"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Every belt is crafted from premium full-grain leather, selected for its natural grain and durability. We work with skilled artisans who take pride in creating belts built for work, weekends, and years of use."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand story"
    }
  ]
}
{% endschema %}
