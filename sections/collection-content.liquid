<section class="collection-content">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="collection-content__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="collection-content__text rte">{{ section.settings.text }}</div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="collection-content__faqs">
        {%- for block in section.blocks -%}
          <div class="collection-content__faq-item" {{ block.shopify_attributes }}>
            {% capture faq_answer %}{{ block.settings.answer }}{% endcapture %}
            {% render 'accordion-panel',
              heading: block.settings.question,
              content: faq_answer,
              open: false,
              id: block.id
            %}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection SEO content",
  "tag": "section",
  "class": "section section--collection-content",
  "settings": [
    {
      "type": "header",
      "content": "SEO Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About This Collection"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Content",
      "default": "<p>Use this space to describe the collection in detail. Explain the leather type, ideal use cases, and what makes these belts special. This content helps customers choose and improves SEO.</p>"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What type of leather is used?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "All belts in this collection are crafted from premium full-grain leather, selected for its natural grain and durability."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection SEO content",
      "settings": {
        "heading": "About This Collection"
      },
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "What type of leather is used?",
            "answer": "All belts in this collection are crafted from premium full-grain leather, selected for its natural grain and durability."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I choose the right size?",
            "answer": "Measure a belt you already own from the buckle edge to the hole you use most. Alternatively, measure your waist where you wear your belt and add 2 inches."
          }
        }
      ]
    }
  ]
}
{% endschema %}
