<section class="collection-related">
  {%- if section.blocks.size > 0 -%}
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="collection-related__grid">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- if coll != blank and coll.all_products_count > 0 -%}
          <a href="{{ coll.url }}" class="collection-card" {{ block.shopify_attributes }}>
            <div class="collection-card__image-wrapper">
              {%- if coll.image -%}
                {%- assign coll_alt = coll.title | escape -%}{{ coll.image | image_url: width: 600 | image_tag: class: 'collection-card__image', widths: '300,600', sizes: '(max-width: 767px) 50vw, 25vw', loading: 'lazy', alt: coll_alt, width: coll.image.width, height: coll.image.height }}
              {%- else -%}
                <div class="collection-card__image collection-card__image--placeholder">
                  {{ 'collection' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
            <div class="collection-card__info">
              <h3 class="collection-card__title">{{ coll.title }}</h3>
              <span class="collection-card__count">{{ coll.all_products_count }} {{ 'collections.general.products' | t }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Related collections",
  "tag": "section",
  "class": "section section--collection-related",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore More Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Related collections",
      "settings": {
        "heading": "Explore More Collections"
      }
    }
  ]
}
{% endschema %}
