<section class="final-cta">
  <div class="page-width">
    <div class="final-cta__card">
      <h2 class="final-cta__heading">{{ section.settings.heading }}</h2>
      <p class="final-cta__text">{{ section.settings.text }}</p>
      {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
        <a href="{{ section.settings.btn_link }}" class="btn btn--primary btn--lg final-cta__btn">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "tag": "section",
  "class": "section section--final-cta",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready for a Belt That Lasts?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Join thousands of South Africans who choose quality leather. Free delivery on orders over R500."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}
