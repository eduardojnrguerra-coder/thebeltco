<section class="hero">
  <div class="hero__media">
    {%- if section.settings.background_image != blank -%}
      {%- assign hero_img = section.settings.background_image -%}
      {%- assign hero_img_alt = section.settings.heading | escape -%}
      {{ hero_img | image_url: width: 1600 | image_tag: class: 'hero__image', widths: '400,800,1200,1600', sizes: '100vw', alt: hero_img_alt, loading: 'eager', fetchpriority: 'high', width: hero_img.width, height: hero_img.height }}
    {%- else -%}
      <div class="hero__image hero__image--placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
    {%- if template.name == 'index' and section.settings.background_image != blank -%}
      <link rel="preload" as="image" href="{{ section.settings.background_image | image_url: width: 800 }}" imagesrcset="{{ section.settings.background_image | image_url: width: 400 }} 400w, {{ section.settings.background_image | image_url: width: 800 }} 800w, {{ section.settings.background_image | image_url: width: 1200 }} 1200w, {{ section.settings.background_image | image_url: width: 1600 }} 1600w" imagesizes="100vw">
    {%- endif -%}
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <div class="page-width hero__content-inner">
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
      <div class="hero__actions">
        {%- if section.settings.primary_btn_label != blank and section.settings.primary_btn_link != blank -%}
          <a href="{{ section.settings.primary_btn_link }}" class="btn btn--primary btn--lg hero__btn">
            {{ section.settings.primary_btn_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_btn_label != blank and section.settings.secondary_btn_link != blank -%}
          <a href="{{ section.settings.secondary_btn_link }}" class="btn btn--outline btn--lg hero__btn hero__btn--secondary">
            {{ section.settings.secondary_btn_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section section--hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Recommended: 1920x1080px, high-quality lifestyle or product image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Leather Belts Made for Everyday Wear"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Durable, timeless belts crafted for work, weekends, and years of use."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "primary_btn_label",
      "label": "Primary button label",
      "default": "Shop Belts"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "secondary_btn_label",
      "label": "Secondary button label",
      "default": "View Best Sellers"
    },
    {
      "type": "url",
      "id": "secondary_btn_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
