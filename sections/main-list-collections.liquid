<section class="main-list-collections">
  <div class="page-width">
    <h1 class="main-list-collections__title">{{ 'collections.general.title' | t }}</h1>

    {%- if collections.size > 0 -%}
      <div class="collection-grid">
        {%- for collection in collections -%}
          {%- if collection.all_products_count > 0 -%}
            <a href="{{ collection.url }}" class="collection-card">
              <div class="collection-card__image-wrapper">
                {%- if collection.image -%}
                  {%- assign list_coll_alt = collection.title | escape -%}{{ collection.image | image_url: width: 600 | image_tag: class: 'collection-card__image', widths: '300,600', sizes: '(max-width: 767px) 50vw, 33vw', loading: 'lazy', alt: list_coll_alt, width: collection.image.width, height: collection.image.height }}
                {%- else -%}
                  <div class="collection-card__image collection-card__image--placeholder">
                    {{ 'collection' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>
              <div class="collection-card__info">
                <h2 class="collection-card__title">{{ collection.title }}</h2>
                <span class="collection-card__count">{{ collection.all_products_count }} {{ 'collections.general.products' | t }}</span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main list collections",
  "tag": "section",
  "class": "section section--main-list-collections",
  "settings": []
}
{% endschema %}
