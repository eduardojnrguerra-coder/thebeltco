<section class="main-register">
  <div class="page-width">
    <div class="customer-form">
      <h1 class="customer-form__title">{{ 'customer.register.title' | t }}</h1>

      {% form 'create_customer', class: 'customer-form__form' %}
        {{ form.errors | default_errors }}

        <div class="customer-form__field">
          <label for="first_name">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" name="customer[first_name]" id="first_name" autocomplete="given-name">
        </div>

        <div class="customer-form__field">
          <label for="last_name">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" name="customer[last_name]" id="last_name" autocomplete="family-name">
        </div>

        <div class="customer-form__field">
          <label for="email">{{ 'customer.register.email' | t }}</label>
          <input type="email" name="customer[email]" id="email" required autocomplete="email">
        </div>

        <div class="customer-form__field">
          <label for="password">{{ 'customer.register.password' | t }}</label>
          <input type="password" name="customer[password]" id="password" required autocomplete="new-password">
        </div>

        <button type="submit" class="btn btn--primary btn--lg customer-form__submit">{{ 'customer.register.submit' | t }}</button>

        <div class="customer-form__links">
          <a href="{{ routes.account_login_url }}">{{ 'customer.register.sign_in' | t }}</a>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main register",
  "tag": "section",
  "class": "section section--main-register",
  "settings": []
}
{% endschema %}
