<section class="main-search">
  <div class="page-width">
    {% render 'breadcrumb' %}

    <h1 class="main-search__title">{{ 'search.general.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" class="main-search__form" role="search">
      <input type="hidden" name="type" value="product">
      <div class="main-search__input-wrapper">
        <input
          class="main-search__input"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.general.placeholder' | t }}"
          autocomplete="off"
        >
        <button class="btn btn--primary main-search__submit" type="submit">
          {{ 'search.general.title' | t }}
        </button>
      </div>
    </form>

    {%- if search.performed -%}
      {%- if search.results.size > 0 -%}
        <p class="main-search__results-count">{{ 'search.general.results_count' | t: count: search.results_count }}</p>
        <div class="product-grid product-grid--4 columns-4">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <div class="product-grid__item">
                {% render 'card-product', product: item, show_quick_add: true %}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if search.results_count > 0 -%}
          {% render 'pagination', paginate: paginate %}
        {%- endif -%}
      {%- else -%}
        <div class="main-search__empty">
          <p>{{ 'search.general.no_results' | t: terms: search.terms }}</p>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main search",
  "tag": "section",
  "class": "section section--main-search",
  "settings": []
}
{% endschema %}
