<section class="recently-viewed" data-recently-viewed data-limit="{{ section.settings.limit }}" style="display: none;">
  <div class="page-width">
    <div class="section-header">
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="product-grid columns-4" data-recently-viewed-grid>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Recently viewed",
  "tag": "section",
  "class": "section section--recently-viewed",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
