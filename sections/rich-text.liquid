<section class="rich-text">
  <div class="page-width">
    <div class="rich-text__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="rich-text__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="rich-text__text">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
        <a href="{{ section.settings.btn_link }}" class="btn btn--outline rich-text__btn">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "class": "section section--rich-text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Rich text"
    }
  ]
}
{% endschema %}
