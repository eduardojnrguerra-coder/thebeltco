<section class="size-guide-teaser">
  <div class="page-width">
    <div class="size-guide-teaser__card">
      {% render 'icon', name: 'ruler', size: 40, classes: 'size-guide-teaser__icon' %}
      <h2 class="size-guide-teaser__heading">{{ section.settings.heading }}</h2>
      <p class="size-guide-teaser__text">{{ section.settings.text }}</p>
      {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
        <a href="{{ section.settings.btn_link }}" class="btn btn--primary size-guide-teaser__btn">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Size guide teaser",
  "tag": "section",
  "class": "section section--size-guide-teaser",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Size"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Not sure which size to order? Our simple size guide will help you get the perfect fit."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Size Guide"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Size guide teaser"
    }
  ]
}
{% endschema %}
