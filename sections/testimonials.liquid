<section class="testimonials">
  <div class="page-width">
    <div class="section-header">
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonials__item" {{ block.shopify_attributes }}>
          {% render 'review-card',
            text: block.settings.text,
            author: block.settings.author,
            rating: block.settings.rating
          %}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size == 0 -%}
      <div class="placeholder-section">
        <p>Add testimonials in the theme editor.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section section--testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial text",
          "default": "The quality of this belt is outstanding. I've been wearing it daily for months and it still looks brand new. Worth every cent."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Thabo M."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "text": "The quality of this belt is outstanding. I've been wearing it daily for months and it still looks brand new.",
            "author": "Thabo M.",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "text": "Best belt I've ever owned. The leather is premium and the craftsmanship is top-notch. Highly recommended!",
            "author": "Sarah van der Merwe",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "text": "Bought this as a gift for my husband. He absolutely loves it. The quality is incredible for the price.",
            "author": "Priya N.",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
