<section class="trust-badges">
  <div class="page-width">
    <div class="trust-badges__grid">
      <div class="trust-badge">
        {% render 'icon', name: 'leaf', size: 32, classes: 'trust-badge__icon' %}
        <span class="trust-badge__text">{{ section.settings.badge_1_text }}</span>
      </div>
      <div class="trust-badge">
        {% render 'icon', name: 'lock', size: 32, classes: 'trust-badge__icon' %}
        <span class="trust-badge__text">{{ section.settings.badge_2_text }}</span>
      </div>
      <div class="trust-badge">
        {% render 'icon', name: 'map-pin', size: 32, classes: 'trust-badge__icon' %}
        <span class="trust-badge__text">{{ section.settings.badge_3_text }}</span>
      </div>
      <div class="trust-badge">
        {% render 'icon', name: 'undo', size: 32, classes: 'trust-badge__icon' %}
        <span class="trust-badge__text">{{ section.settings.badge_4_text }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "tag": "section",
  "class": "section section--trust-badges",
  "settings": [
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Text",
      "default": "Genuine Leather"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Text",
      "default": "Secure Checkout"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Text",
      "default": "South African Store"
    },
    {
      "type": "header",
      "content": "Badge 4"
    },
    {
      "type": "text",
      "id": "badge_4_text",
      "label": "Text",
      "default": "Easy Returns"
    }
  ],
  "presets": [
    {
      "name": "Trust badges"
    }
  ]
}
{% endschema %}
