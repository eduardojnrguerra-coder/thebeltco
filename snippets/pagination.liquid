{%- if paginate.pages > 1 -%}
  <nav class="pagination" role="navigation" aria-label="Pagination">
    <ul class="pagination__list">
      {%- if paginate.previous -%}
        <li class="pagination__item pagination__item--prev">
          <a class="pagination__link" href="{{ paginate.previous.url }}" aria-label="{{ 'collections.general.previous' | t }}">
            {% render 'icon', name: 'chevron-left', size: 20 %}
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        <li class="pagination__item{% if part.is_link == false %} pagination__item--active{% endif %}">
          {%- if part.is_link -%}
            <a class="pagination__link" href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="pagination__link pagination__link--current" aria-current="page">{{ part.title }}</span>
          {%- endif -%}
        </li>
      {%- endfor -%}

      {%- if paginate.next -%}
        <li class="pagination__item pagination__item--next">
          <a class="pagination__link" href="{{ paginate.next.url }}" aria-label="{{ 'collections.general.next' | t }}">
            {% render 'icon', name: 'chevron-right', size: 20 %}
          </a>
        </li>
      {%- endif -%}
    </ul>
  </nav>
{%- endif -%}
