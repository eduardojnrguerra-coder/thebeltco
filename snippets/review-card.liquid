{%- liquid
  assign text = text | default: ''
  assign author = author | default: ''
  assign rating = rating | default: 5
  assign avatar = avatar | default: ''
-%}

<div class="review-card">
  <div class="review-card__stars">
    {%- for i in (1..5) -%}
      <svg class="review-card__star{% if forloop.index <= rating %} review-card__star--filled{% endif %}" width="18" height="18" viewBox="0 0 24 24" fill="{% if forloop.index <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="2">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    {%- endfor -%}
  </div>
  <blockquote class="review-card__text">{{ text }}</blockquote>
  <div class="review-card__author">
    {%- if avatar != blank -%}
      <div class="review-card__avatar">
        {{ avatar | image_url: width: 80 | image_tag: loading: 'lazy', widths: '40,80', class: 'review-card__avatar-img' }}
      </div>
    {%- endif -%}
    <cite class="review-card__author-name">{{ author }}</cite>
  </div>
</div>
